# AgentOS Docker 环境变量配置
# 使用说明:
# 1. 复制此文件为 .env
# 2. 根据实际情况修改配置值
# 3. docker-compose 会自动加载此文件

# ==================== API 密钥配置 ====================

# OpenAI API 密钥
# 获取地址：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# DeepSeek API 密钥
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Anthropic API 密钥 (Claude)
# 获取地址：https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ==================== 数据库配置 ====================

# PostgreSQL 数据库密码
# 默认用户名：agentos
# 默认数据库名：agentos
POSTGRES_PASSWORD=agentos_secure_password_123

# Redis 密码（可选）
# REDIS_PASSWORD=your-redis-password

# ==================== 日志配置 ====================

# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
AGENTOS_LOG_LEVEL=INFO

# 日志格式：json, text
AGENTOS_LOG_FORMAT=text

# 是否启用结构化日志
AGENTOS_STRUCTURED_LOGGING=false

# ==================== 追踪和监控配置 ====================

# OpenTelemetry 收集器端点
AGENTOS_TELEMETRY_ENDPOINT=http://otel-collector:4317

# 是否启用分布式追踪
AGENTOS_ENABLE_TRACING=true

# 追踪采样率 (0.0-1.0)
AGENTOS_TRACING_SAMPLE_RATE=1.0

# ==================== 服务端口配置 ====================

# LLM 服务端口
LLM_SERVICE_PORT=8080

# 工具服务端口
TOOL_SERVICE_PORT=8081

# 市场服务端口
MARKET_SERVICE_PORT=8082

# 调度服务端口
SCHED_SERVICE_PORT=8083

# 监控服务端口
MONIT_SERVICE_PORT=8084

# ==================== 性能调优配置 ====================

# 最大工作进程数
AGENTOS_MAX_WORKERS=8

# LLM 请求超时时间（秒）
LLM_REQUEST_TIMEOUT=120

# 缓存大小（MB）
AGENTOS_CACHE_SIZE_MB=512

# 向量检索索引类型：IVF, HNSW
MEMORY_VECTOR_INDEX_TYPE=HNSW

# 向量检索维度
MEMORY_VECTOR_DIMENSION=768

# ==================== 内存管理配置 ====================

# LRU 缓存大小（条目数）
MEMORY_LRU_CACHE_SIZE=10000

# 记忆写入批处理大小
MEMORY_BATCH_SIZE=100

# 异步写入队列大小
MEMORY_ASYNC_QUEUE_SIZE=1000

# ==================== 安全配置 ====================

# JWT 密钥（用于 API 认证）
# 生成方法：openssl rand -hex 32
AGENTOS_JWT_SECRET=your-jwt-secret-key-change-in-production

# API 速率限制（每分钟请求数）
API_RATE_LIMIT=100

# 是否启用 CORS
ENABLE_CORS=true

# WARNING: In production, restrict CORS origins to your frontend domain(s)
# 允许的 CORS 源（逗号分隔）
CORS_ALLOWED_ORIGINS=${CORS_ALLOWED_ORIGINS:-http://localhost:3000}

# ==================== 存储路径配置 ====================

# 数据根目录（容器内路径）
AGENTOS_DATA_ROOT=/var/lib/agentos

# 日志根目录（容器内路径）
AGENTOS_LOG_ROOT=/var/log/agentos

# 配置文件根目录（容器内路径）
AGENTOS_CONFIG_ROOT=/etc/agentos

# ==================== 其他配置 ====================

# 时区
TZ=Asia/Shanghai

# 是否启用 GPU 加速
GPU_ENABLED=false

# CUDA 设备 ID（多 GPU 环境）
CUDA_VISIBLE_DEVICES=0

# 模型缓存目录
MODEL_CACHE_DIR=/var/lib/agentos/models

# 临时文件目录
TMP_DIR=/tmp/agentos

# ==================== 开发配置 ====================

# 是否启用调试模式
DEBUG_MODE=false

# 是否启用热重载
ENABLE_HOT_RELOAD=false

# 开发服务器地址
DEV_SERVER_HOST=0.0.0.0

# 开发服务器端口
DEV_SERVER_PORT=9000
