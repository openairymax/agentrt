# AgentOS 服务层镜像
# 自包含构建，提供完整的后端服务运行时环境

# === 1. 构建阶段 ===
FROM ubuntu:22.04 AS builder

LABEL maintainer="SPHARX Team <devops@spharx.cn>"

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential cmake ninja-build gcc g++ \
    libssl-dev libcurl4-openssl-dev libcjson-dev libyaml-dev \
    libsqlite3-dev libmicrohttpd-dev libwebsockets-dev \
    libevent-dev libcmocka-dev \
    pkg-config git ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

COPY . ./AgentOS/

# BAN-33: 构建目录在源码树外
RUN mkdir -p /workspace/AgentOS-build \
    && cmake -S /workspace/AgentOS -B /workspace/AgentOS-build \
    -DCMAKE_BUILD_TYPE=Release \
    -DBUILD_TESTS=OFF \
    -DCMAKE_INSTALL_PREFIX=/opt/agentos \
    -G Ninja \
    && cmake --build /workspace/AgentOS-build --parallel $(nproc) \
    && cmake --install /workspace/AgentOS-build

# === 2. 运行时阶段 ===
FROM ubuntu:22.04 AS gateway

LABEL maintainer="SPHARX Team <devops@spharx.cn>"
LABEL version="0.0.5"
LABEL description="AgentOS Service Layer Image"

ENV DEBIAN_FRONTEND=noninteractive \
    TZ=Asia/Shanghai \
    AGENTOS_SERVICES_ROOT=/opt/agentos/services \
    AGENTOS_LOG_DIR=/var/log/agentos \
    AGENTOS_CONFIG_DIR=/etc/agentos \
    PATH=/opt/agentos/services/bin:$PATH \
    LD_LIBRARY_PATH=/opt/agentos/services/lib:$LD_LIBRARY_PATH

# 时区设置
RUN ln -fs /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && \
    dpkg-reconfigure -f noninteractive tzdata

# 安装运行时依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    libssl3 \
    libevent-2.1-7 \
    libsqlite3-0 \
    libcjson1 \
    libcurl4 \
    libyaml-0-2 \
    libmicrohttpd12 \
    libwebsockets19 \
    python3 \
    python3-pip \
    netcat-openbsd \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# 创建目录结构
RUN mkdir -p ${AGENTOS_SERVICES_ROOT}/{bin,lib,etc,var} \
    && mkdir -p ${AGENTOS_CONFIG_DIR}/{services,kernel} \
    && mkdir -p ${AGENTOS_LOG_DIR}/{services,kernel,traces} \
    && mkdir -p /var/lib/agentos/{registry,sessions,memory} \
    && chmod -R 755 ${AGENTOS_SERVICES_ROOT} \
    && chmod -R 755 ${AGENTOS_LOG_DIR} \
    && chmod -R 755 /var/lib/agentos

# 从构建阶段复制已安装的文件
COPY --from=builder /opt/agentos /opt/agentos

# 创建非 root 用户
RUN groupadd -r agentos && \
    useradd -r -g agentos -d /var/lib/agentos -s /sbin/nologin agentos && \
    chown -R agentos:agentos /var/lib/agentos \
    && chown -R agentos:agentos ${AGENTOS_LOG_DIR} \
    && chown -R agentos:agentos ${AGENTOS_SERVICES_ROOT}

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD nc -z localhost 8080 || nc -z localhost 8081 || exit 1

# 暴露端口（各服务的 REST API）
EXPOSE 8080 8081 8082 8083 8084

WORKDIR ${AGENTOS_SERVICES_ROOT}

CMD ["/bin/bash"]
