{\n  "name": "videoedit",\n  "version": "1.0.0",\n  "description": "Video Editing Platform for OpenLab",\n  "author": "Spharx AgentOS Team",\n  "license": "MIT",\n  "entry_point": "src.main:main",\n  "dependencies": [\n    "fastapi>=0.104.0",\n    "uvicorn>=0.24.0",\n    "opencv-python>=4.8.0",\n    "moviepy>=1.0.3",\n    "pydantic>=2.4.0",\n    "numpy>=1.24.0",\n    "pillow>=10.0.0",\n    "aiofiles>=23.0.0",\n    "python-multipart>=0.0.6"\n  ],\n  "capabilities": [\n    "video_import",\n    "video_export",\n    "clip_trimming",\n    "video_merging",\n    "video_effects",\n    "audio_processing",\n    "subtitle_generation",\n    "thumbnail_extraction",\n    "format_conversion"\n  ],\n  "config_schema": {\n    "type": "object",\n    "properties": {\n      "output_dir": {\n        "type": "string",\n        "description": "Directory for output files"\n      },\n      "temp_dir": {\n        "type": "string",\n        "description": "Directory for temporary files"\n      },\n      "max_file_size": {\n        "type": "integer",\n        "description": "Maximum file size in bytes"\n      },\n      "supported_formats": {\n        "type": "array",\n        "items": {\n          "type": "string"\n        },\n        "description": "Supported video formats"\n      },\n      "ffmpeg_path": {\n        "type": "string",\n        "description": "Path to FFmpeg binary"\n      },\n      "port": {\n        "type": "integer",\n        "description": "Server port",\n        "default": 8001\n      },\n      "host": {\n        "type": "string",\n        "description": "Server host",\n        "default": "0.0.0.0"\n      }\n    },\n    "required": [\n      "output_dir",\n      "temp_dir"\n    ]\n  }\n}