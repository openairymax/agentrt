<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ file.title }} - {{ manager.get('template_variables', {}).get('project_name', 'openlab Documentation') }}</title>
    
    <style>
        :root {
            --primary-color: {{ manager.get('theme_options', {}).get('primary_color', '#2563eb') }};
            --secondary-color: {{ manager.get('theme_options', {}).get('secondary_color', '#7c3aed') }};
            --font-family: {{ manager.get('theme_options', {}).get('font_family', 'Inter, system-ui, sans-serif') }};
            --code-font: {{ manager.get('theme_options', {}).get('code_font', 'JetBrains Mono, monospace') }};
            --bg-color: #ffffff;
            --text-color: #1f2937;
            --code-bg: #f3f4f6;
            --border-color: #e5e7eb;
            --sidebar-width: 280px;
        }
        
        @media (prefers-color-scheme: dark) {
            :root {
                --bg-color: #111827;
                --text-color: #f3f4f6;
                --code-bg: #1f2937;
                --border-color: #374151;
            }
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: var(--font-family);
            line-height: 1.6;
            color: var(--text-color);
            background-color: var(--bg-color);
            display: flex;
            min-height: 100vh;
        }
        
        .sidebar {
            width: var(--sidebar-width);
            background: var(--bg-color);
            border-right: 1px solid var(--border-color);
            padding: 2rem;
            position: fixed;
            height: 100vh;
            overflow-y: auto;
        }
        
        .main-content {
            flex: 1;
            margin-left: var(--sidebar-width);
            padding: 2rem;
            max-width: 800px;
        }
        
        .logo {
            font-size: 1.5rem;
            font-weight: bold;
            color: var(--primary-color);
            margin-bottom: 2rem;
            text-decoration: none;
            display: block;
        }
        
        .nav-section {
            margin-bottom: 2rem;
        }
        
        .nav-title {
            font-size: 0.875rem;
            text-transform: uppercase;
            color: #6b7280;
            font-weight: 600;
            margin-bottom: 0.75rem;
            letter-spacing: 0.05em;
        }
        
        .nav-links {
            list-style: none;
        }
        
        .nav-links li {
            margin-bottom: 0.5rem;
        }
        
        .nav-links a {
            color: var(--text-color);
            text-decoration: none;
            padding: 0.375rem 0.75rem;
            border-radius: 0.375rem;
            display: block;
            transition: all 0.2s;
        }
        
        .nav-links a:hover {
            background-color: var(--code-bg);
            color: var(--primary-color);
        }
        
        .nav-links a.active {
            background-color: var(--primary-color);
            color: white;
        }
        
        .header {
            margin-bottom: 2rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--border-color);
        }
        
        .title {
            font-size: 2.5rem;
            font-weight: bold;
            color: var(--text-color);
            margin-bottom: 0.5rem;
        }
        
        .description {
            color: #6b7280;
            font-size: 1.125rem;
            margin-bottom: 1rem;
        }
        
        .metadata {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            margin-bottom: 1rem;
        }
        
        .metadata-item {
            display: flex;
            align-items: center;
            gap: 0.375rem;
            font-size: 0.875rem;
            color: #6b7280;
        }
        
        .metadata-item svg {
            width: 1rem;
            height: 1rem;
        }
        
        .tags {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            margin-bottom: 1rem;
        }
        
        .tag {
            background-color: var(--code-bg);
            color: var(--text-color);
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.875rem;
        }
        
        .content {
            margin-bottom: 3rem;
        }
        
        .content h1, .content h2, .content h3, .content h4, .content h5, .content h6 {
            margin-top: 2rem;
            margin-bottom: 1rem;
            color: var(--text-color);
        }
        
        .content h1 { font-size: 2rem; }
        .content h2 { font-size: 1.75rem; }
        .content h3 { font-size: 1.5rem; }
        .content h4 { font-size: 1.25rem; }
        
        .content p {
            margin-bottom: 1rem;
        }
        
        .content ul, .content ol {
            margin-bottom: 1rem;
            padding-left: 1.5rem;
        }
        
        .content li {
            margin-bottom: 0.5rem;
        }
        
        .content code {
            font-family: var(--code-font);
            background-color: var(--code-bg);
            padding: 0.125rem 0.375rem;
            border-radius: 0.25rem;
            font-size: 0.875rem;
        }
        
        .content pre {
            background-color: var(--code-bg);
            padding: 1rem;
            border-radius: 0.5rem;
            overflow-x: auto;
            margin-bottom: 1rem;
        }
        
        .content pre code {
            background: none;
            padding: 0;
        }
        
        .content blockquote {
            border-left: 4px solid var(--primary-color);
            padding-left: 1rem;
            margin-left: 0;
            margin-right: 0;
            margin-bottom: 1rem;
            color: #6b7280;
        }
        
        .content table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 1rem;
        }
        
        .content th, .content td {
            border: 1px solid var(--border-color);
            padding: 0.75rem;
            text-align: left;
        }
        
        .content th {
            background-color: var(--code-bg);
            font-weight: 600;
        }
        
        .content img {
            max-width: 100%;
            height: auto;
            border-radius: 0.5rem;
            margin-bottom: 1rem;
        }
        
        .footer {
            margin-top: 3rem;
            padding-top: 2rem;
            border-top: 1px solid var(--border-color);
            color: #6b7280;
            font-size: 0.875rem;
        }
        
        .footer a {
            color: var(--primary-color);
            text-decoration: none;
        }
        
        .footer a:hover {
            text-decoration: underline;
        }
        
        .breadcrumbs {
            margin-bottom: 1rem;
            font-size: 0.875rem;
            color: #6b7280;
        }
        
        .breadcrumbs a {
            color: var(--primary-color);
            text-decoration: none;
        }
        
        .breadcrumbs a:hover {
            text-decoration: underline;
        }
        
        .breadcrumbs span {
            margin: 0 0.375rem;
        }
        
        .search-box {
            margin-bottom: 2rem;
        }
        
        .search-input {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 1px solid var(--border-color);
            border-radius: 0.5rem;
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: var(--font-family);
            font-size: 1rem;
        }
        
        .search-input:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        }
        
        @media (max-width: 768px) {
            body {
                flex-direction: column;
            }
            
            .sidebar {
                width: 100%;
                height: auto;
                position: static;
                border-right: none;
                border-bottom: 1px solid var(--border-color);
            }
            
            .main-content {
                margin-left: 0;
            }
        }
    </style>
    
    {% if manager.get('analytics', {}).get('enabled', false) %}
    <!-- Analytics -->
    {% if manager.get('analytics', {}).get('provider') == 'google' %}
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ manager.get('analytics', {}).get('tracking_id', '') }}"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('manager', '{{ manager.get('analytics', {}).get('tracking_id', '') }}');
    </script>
    {% endif %}
    {% endif %}
</head>
<body>
    <nav class="sidebar">
        <a href="/" class="logo">
            {{ manager.get('template_variables', {}).get('project_name', 'openlab Documentation') }}
        </a>
        
        {% if manager.get('enable_search', true) %}
        <div class="search-box">
            <input type="text" class="search-input" placeholder="Search documentation..." id="search-input">
        </div>
        {% endif %}
        
        {% if navigation %}
        <div class="nav-section">
            <div class="nav-title">Navigation</div>
            <ul class="nav-links">
                {% for section in navigation.sections %}
                <li>
                    <a href="{{ section.path }}" {% if section.active %}class="active"{% endif %}>
                        {{ section.title }}
                    </a>
                </li>
                {% endfor %}
            </ul>
        </div>
        {% endif %}
        
        <div class="nav-section">
            <div class="nav-title">File Info</div>
            <ul class="nav-links">
                <li>
                    <a href="#">
                        <strong>Type:</strong> {{ file.file_type.value }}
                    </a>
                </li>
                <li>
                    <a href="#">
                        <strong>Size:</strong> {{ (file.size / 1024)|round(2) }} KB
                    </a>
                </li>
                <li>
                    <a href="#">
                        <strong>Modified:</strong> {{ file.modified_time|datetime }}
                    </a>
                </li>
            </ul>
        </div>
        
        {% if file.dependencies %}
        <div class="nav-section">
            <div class="nav-title">Dependencies</div>
            <ul class="nav-links">
                {% for dep in file.dependencies %}
                <li><a href="#">{{ dep }}</a></li>
                {% endfor %}
            </ul>
        </div>
        {% endif %}
    </nav>
    
    <main class="main-content">
        <div class="breadcrumbs">
            {% for crumb in breadcrumbs %}
            <a href="{{ crumb.path }}">{{ crumb.name }}</a>
            {% if not loop.last %}<span>/</span>{% endif %}
            {% endfor %}
        </div>
        
        <header class="header">
            <h1 class="title">{{ file.title }}</h1>
            
            {% if file.description %}
            <p class="description">{{ file.description }}</p>
            {% endif %}
            
            <div class="metadata">
                <div class="metadata-item">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Generated: {{ now().strftime('%Y-%m-%d %H:%M') }}
                </div>
                
                <div class="metadata-item">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Version: {{ manager.get('template_variables', {}).get('version', '1.0.0') }}
                </div>
            </div>
            
            {% if file.tags %}
            <div class="tags">
                {% for tag in file.tags %}
                <span class="tag">{{ tag }}</span>
                {% endfor %}
            </div>
            {% endif %}
        </header>
        
        <div class="content">
            {% if file.file_type.value == 'markdown' %}
            {{ html_content|safe }}
            {% elif file.file_type.value == 'python' %}
            <pre><code class="language-python">{{ content }}</code></pre>
            {% elif file.file_type.value in ['yaml', 'json'] %}
            <pre><code class="language-{{ file.file_type.value }}">{{ formatted_content }}</code></pre>
            {% else %}
            <pre><code>{{ content }}</code></pre>
            {% endif %}
        </div>
        
        <footer class="footer">
            <p>
                Generated by 
                <a href="https://github.com/spharx/AgentOS" target="_blank">
                    openlab Documentation Generator
                </a>
                • 
                <a href="{{ file.path }}" target="_blank">View Source</a>
            </p>
            <p>
                © {{ now().year }} {{ manager.get('template_variables', {}).get('author', 'SPHARX Team') }}.
                All rights reserved.
            </p>
        </footer>
    </main>
    
    {% if manager.get('enable_search', true) %}
    <script>
        // Simple search functionality
        document.getElementById('search-input').addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const navLinks = document.querySelectorAll('.nav-links a');
            
            navLinks.forEach(link => {
                const text = link.textContent.toLowerCase();
                if (text.includes(searchTerm)) {
                    link.style.display = 'block';
                } else {
                    link.style.display = 'none';
                }
            });
        });
        
        // Load search index if available
        {% if manager.get('enable_search', true) %}
        fetch('{{ manager.get("search_index_file", "search_index.json") }}')
            .then(response => response.json())
            .then(data => {
                console.log('Search index loaded:', data);
                // Implement full-text search here
            })
            .catch(error => console.log('Search index not available:', error));
        {% endif %}
    </script>
    {% endif %}
</body>
</html>