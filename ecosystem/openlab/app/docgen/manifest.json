{\n  "name": "docgen",\n  "version": "1.0.0",\n  "description": "Documentation Generator for openlab Projects",\n  "author": "Spharx AgentOS Team",\n  "license": "MIT",\n  "entry_point": "src.main:main",\n  "dependencies": [\n    "markdown>=3.5.0",\n    "pyyaml>=6.0",\n    "jinja2>=3.1.0",\n    "watchdog>=3.0.0"\n  ],\n  "capabilities": [\n    "documentation_generation",\n    "markdown_processing",\n    "template_rendering",\n    "file_watching"\n  ],\n  "config_schema": {\n    "type": "object",\n    "properties": {\n      "input_dir": {\n        "type": "string",\n        "description": "Input directory containing source files"\n      },\n      "output_dir": {\n        "type": "string",\n        "description": "Output directory for generated documentation"\n      },\n      "template_dir": {\n        "type": "string",\n        "description": "Directory containing Jinja2 templates"\n      },\n      "watch_mode": {\n        "type": "boolean",\n        "description": "Enable file watching for automatic regeneration",\n        "default": false\n      },\n      "include_patterns": {\n        "type": "array",\n        "items": {\n          "type": "string"\n        },\n        "description": "File patterns to include",\n        "default": ["*.md", "*.py", "*.yaml", "*.json"]\n      },\n      "exclude_patterns": {\n        "type": "array",\n        "items": {\n          "type": "string"\n        },\n        "description": "File patterns to exclude",\n        "default": ["__pycache__", "*.pyc", ".git", "node_modules"]\n      }\n    },\n    "required": ["input_dir", "output_dir"]\n  }\n}