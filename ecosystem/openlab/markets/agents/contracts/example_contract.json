{
  "agent_id": "architect-agent",
  "agent_type": "architect",
  "version": "1.0.0",
  "capabilities": [
    "architecture_design",
    "code_generation",
    "code_review"
  ],
  "description": "An intelligent architect agent that designs software architectures and generates code based on requirements.",
  "config_schema": {
    "type": "object",
    "properties": {
      "llm_provider": {
        "type": "string",
        "enum": ["openai", "anthropic", "local"],
        "default": "openai"
      },
      "llm_model": {
        "type": "string",
        "default": "gpt-4"
      },
      "max_tokens": {
        "type": "integer",
        "minimum": 100,
        "maximum": 4000,
        "default": 2000
      },
      "temperature": {
        "type": "number",
        "minimum": 0.0,
        "maximum": 2.0,
        "default": 0.7
      }
    },
    "required": ["llm_provider"]
  },
  "entry_point": "openlab.agents.architect.agent:ArchitectAgent",
  "dependencies": [
    {
      "name": "openai",
      "version": ">=1.0.0"
    },
    {
      "name": "jsonschema",
      "version": ">=4.17.0"
    }
  ],
  "resource_requirements": {
    "memory_mb": 512,
    "cpu_cores": 1.0,
    "disk_mb": 100
  },
  "tags": {
    "category": "development",
    "complexity": "advanced",
    "language": "python"
  },
  "license": "AGPL-3.0-or-later OR Apache-2.0",
  "author": "SPHARX Ltd. - Airymax Team",
  "repository": "https://github.com/spharx/AgentRT"
}