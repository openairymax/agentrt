{\n  "agent_id": "architect-agent",\n  "agent_type": "architect",\n  "version": "1.0.0",\n  "capabilities": [\n    "architecture_design",\n    "code_generation",\n    "code_review"\n  ],\n  "description": "An intelligent architect agent that designs software architectures and generates code based on requirements.",\n  "config_schema": {\n    "type": "object",\n    "properties": {\n      "llm_provider": {\n        "type": "string",\n        "enum": [\n          "openai",\n          "anthropic",\n          "local"\n        ],\n        "default": "openai"\n      },\n      "llm_model": {\n        "type": "string",\n        "default": "gpt-4"\n      },\n      "max_tokens": {\n        "type": "integer",\n        "minimum": 100,\n        "maximum": 4000,\n        "default": 2000\n      },\n      "temperature": {\n        "type": "number",\n        "minimum": 0.0,\n        "maximum": 2.0,\n        "default": 0.7\n      }\n    },\n    "required": [\n      "llm_provider"\n    ]\n  },\n  "entry_point": "openlab.agents.architect.agent:ArchitectAgent",\n  "dependencies": [\n    {\n      "name": "openai",\n      "version": ">=1.0.0"\n    },\n    {\n      "name": "jsonschema",\n      "version": ">=4.17.0"\n    }\n  ],\n  "resource_requirements": {\n    "memory_mb": 512,\n    "cpu_cores": 1.0,\n    "disk_mb": 100\n  },\n  "tags": {\n    "category": "development",\n    "complexity": "advanced",\n    "language": "python"\n  },\n  "license": "MIT",\n  "author": "Spharx AgentOS Team",\n  "repository": "https://github.com/spharx/AgentOS"\n}