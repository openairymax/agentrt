{\n  "$schema": "http://json-schema.org/draft-07/schema#",\n  "title": "Agent Contract Schema",\n  "description": "Schema for validating Agent contracts in openlab Market",\n  "type": "object",\n  "required": [\n    "agent_id",\n    "agent_type",\n    "version",\n    "capabilities",\n    "description",\n    "config_schema",\n    "entry_point"\n  ],\n  "properties": {\n    "agent_id": {\n      "type": "string",\n      "description": "Unique identifier for the agent",\n      "pattern": "^[a-z0-9-]+$",\n      "minLength": 3,\n      "maxLength": 100\n    },\n    "agent_type": {\n      "type": "string",\n      "description": "Semantic type of the agent",\n      "enum": [\n        "architect",\n        "backend",\n        "frontend",\n        "devops",\n        "security",\n        "tester",\n        "product_manager",\n        "data_analyst",\n        "researcher",\n        "custom"\n      ]\n    },\n    "version": {\n      "type": "string",\n      "description": "Agent version in semantic versioning format",\n      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9]+)?$"\n    },\n    "capabilities": {\n      "type": "array",\n      "description": "List of capabilities this agent provides",\n      "items": {\n        "type": "string",\n        "enum": [\n          "code_generation",\n          "code_review",\n          "architecture_design",\n          "data_analysis",\n          "documentation",\n          "test_generation",\n          "deployment",\n          "monitoring",\n          "security_audit",\n          "api_integration",\n          "database_design",\n          "frontend_development",\n          "backend_development",\n          "devops_automation",\n          "research_analysis"\n        ]\n      },\n      "minItems": 1\n    },\n    "description": {\n      "type": "string",\n      "description": "Human-readable description of the agent",\n      "minLength": 10,\n      "maxLength": 1000\n    },\n    "config_schema": {\n      "type": "object",\n      "description": "JSON Schema for agent configuration",\n      "properties": {\n        "type": {\n          "type": "string",\n          "const": "object"\n        },\n        "properties": {\n          "type": "object"\n        },\n        "required": {\n          "type": "array",\n          "items": {\n            "type": "string"\n          }\n        }\n      },\n      "required": ["type", "properties"]\n    },\n    "entry_point": {\n      "type": "string",\n      "description": "Python import path to the agent class",\n      "pattern": "^[a-zA-Z0-9_.]+:[a-zA-Z0-9_]+$"\n    },\n    "dependencies": {\n      "type": "array",\n      "description": "List of required dependencies",\n      "items": {\n        "type": "object",\n        "properties": {\n          "name": {\n            "type": "string"\n          },\n          "version": {\n            "type": "string"\n          }\n        },\n        "required": ["name"]\n      }\n    },\n    "resource_requirements": {\n      "type": "object",\n      "description": "Resource requirements for the agent",\n      "properties": {\n        "memory_mb": {\n          "type": "integer",\n          "minimum": 10\n        },\n        "cpu_cores": {\n          "type": "number",\n          "minimum": 0.1\n        },\n        "disk_mb": {\n          "type": "integer",\n          "minimum": 1\n        }\n      }\n    },\n    "tags": {\n      "type": "object",\n      "description": "Key-value tags for discovery",\n      "additionalProperties": {\n        "type": "string"\n      }\n    },\n    "license": {\n      "type": "string",\n      "description": "License information",\n      "enum": ["MIT", "Apache-2.0", "GPL-3.0", "BSD-3-Clause", "Proprietary"]\n    },\n    "author": {\n      "type": "string",\n      "description": "Author or organization name"\n    },\n    "repository": {\n      "type": "string",\n      "description": "URL to source code repository",\n      "format": "uri"\n    }\n  },\n  "additionalProperties": false\n}