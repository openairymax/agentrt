{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentos.spharx.com/schemas/tool-service.schema.json",
  "title": "AgentOS Tool Service Configuration Schema",
  "description": "Schema for Tool Daemon service configuration",
  "type": "object",
  "required": ["_config_version", "tool_d"],
  "properties": {
    "_config_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Configuration version in semantic versioning format"
    },
    "tool_d": {
      "type": "object",
      "required": ["name", "version", "enabled", "bind_address", "port", "max_concurrency", "timeout_sec"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "description": "Service name",
          "examples": ["tool-daemon", "agentos-tool-service"]
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(\\.\\d+)?$",
          "description": "Service version",
          "examples": ["1.0.0", "1.2.0", "2.0.0"]
        },
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Whether the service is enabled",
          "examples": [true, false]
        },
        "bind_address": {
          "type": "string",
          "format": "ipv4",
          "default": "127.0.0.1",
          "description": "Service bind address",
          "examples": ["127.0.0.1", "0.0.0.0", "192.168.1.100"]
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "default": 50051,
          "description": "Service port",
          "examples": [50051, 50052, 8080]
        },
        "max_concurrency": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000,
          "default": 100,
          "description": "Maximum concurrent requests",
          "examples": [50, 100, 200, 500]
        },
        "timeout_sec": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600,
          "default": 60,
          "description": "Request timeout in seconds",
          "examples": [30, 60, 120, 300]
        },
        "execution": {
          "type": "object",
          "description": "Execution configuration",
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["local", "docker", "wasm", "remote"],
              "default": "local",
              "description": "Execution mode",
              "examples": ["local", "docker", "wasm"]
            },
            "sandbox": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Enable sandbox isolation",
                  "examples": [true, false]
                },
                "type": {
                  "type": "string",
                  "enum": ["process", "container", "wasm"],
                  "description": "Sandbox type",
                  "examples": ["process", "container"]
                },
                "memory_limit_mb": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Memory limit in MB",
                  "examples": [128, 256, 512, 1024]
                },
                "cpu_limit": {
                  "type": "number",
                  "minimum": 0.1,
                  "description": "CPU limit (cores)",
                  "examples": [0.5, 1.0, 2.0, 4.0]
                },
                "timeout_sec": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Timeout in seconds",
                  "examples": [30, 60, 120, 300]
                }
              }
            },
            "docker": {
              "type": "object",
              "properties": {
                "image": {
                  "type": "string"
                },
                "network": {
                  "type": "string"
                },
                "read_only": {
                  "type": "boolean"
                },
                "security_opt": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "cap_drop": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "wasm": {
              "type": "object",
              "properties": {
                "runtime": {
                  "type": "string"
                },
                "memory_limit_mb": {
                  "type": "integer"
                },
                "timeout_sec": {
                  "type": "integer"
                }
              }
            }
          }
        },
        "cache": {
          "type": "object",
          "description": "Cache configuration",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable caching",
              "examples": [true, false]
            },
            "type": {
              "type": "string",
              "enum": ["memory", "redis", "file"],
              "description": "Cache backend type",
              "examples": ["memory", "redis"]
            },
            "memory": {
              "type": "object",
              "properties": {
                "max_size_mb": {
                  "type": "integer",
                  "description": "Max cache size in MB",
                  "examples": [64, 128, 256, 512]
                },
                "ttl_sec": {
                  "type": "integer",
                  "description": "Cache TTL in seconds",
                  "examples": [300, 600, 1800, 3600]
                }
              }
            },
            "redis": {
              "type": "object",
              "properties": {
                "host": {
                  "type": "string",
                  "description": "Redis host (supports environment variable syntax)",
                  "examples": ["localhost", "redis.local", "${REDIS_HOST:-localhost}"]
                },
                "port": {
                  "oneOf": [
                    {"type": "integer", "minimum": 1, "maximum": 65535},
                    {"type": "string", "pattern": "^\\$\\{[^}]+\\}$"}
                  ],
                  "description": "Redis port (integer or environment variable syntax)",
                  "examples": [6379, 6380, "${REDIS_PORT:-6379}"]
                },
                "db": {
                  "oneOf": [
                    {"type": "integer", "minimum": 0, "maximum": 15},
                    {"type": "string", "pattern": "^\\$\\{[^}]+\\}$"}
                  ],
                  "description": "Redis database number (integer or environment variable syntax)",
                  "examples": [0, 1, 2, "${REDIS_DB:-0}"]
                },
                "ttl_sec": {
                  "type": "integer",
                  "description": "Cache TTL in seconds",
                  "examples": [3600, 7200, 86400]
                }
              }
            },
            "file": {
              "type": "object",
              "properties": {
                "dir": {
                  "type": "string"
                },
                "max_size_mb": {
                  "type": "integer"
                },
                "ttl_sec": {
                  "type": "integer"
                }
              }
            }
          }
        },
        "permissions": {
          "type": "object",
          "description": "Permission configuration",
          "properties": {
            "default_rule": {
              "type": "string",
              "enum": ["allow", "deny"],
              "description": "Default permission rule",
              "examples": ["deny", "allow"]
            },
            "check_enabled": {
              "type": "boolean",
              "description": "Enable permission checking",
              "examples": [true, false]
            },
            "audit_enabled": {
              "type": "boolean",
              "description": "Enable permission audit",
              "examples": [true, false]
            }
          }
        },
        "logging": {
          "type": "object",
          "description": "Logging configuration",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable logging",
              "examples": [true, false]
            },
            "log_input": {
              "type": "boolean",
              "description": "Log input data",
              "examples": [true, false]
            },
            "log_output": {
              "type": "boolean",
              "description": "Log output data",
              "examples": [true, false]
            },
            "log_duration": {
              "type": "boolean",
              "description": "Log execution duration",
              "examples": [true, false]
            },
            "mask_fields": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Fields to mask in logs",
              "examples": [["password", "token", "api_key"], ["secret"]]
            }
          }
        },
        "health_check": {
          "type": "object",
          "description": "Health check configuration",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable health checks",
              "examples": [true, false]
            },
            "interval_sec": {
              "type": "integer",
              "minimum": 1,
              "description": "Health check interval",
              "examples": [10, 30, 60]
            },
            "timeout_sec": {
              "type": "integer",
              "minimum": 1,
              "description": "Health check timeout",
              "examples": [5, 10, 30]
            },
            "unhealthy_threshold": {
              "type": "integer",
              "minimum": 1,
              "description": "Unhealthy threshold",
              "examples": [3, 5, 10]
            }
          }
        },
        "rate_limit": {
          "type": "object",
          "description": "Rate limiting configuration",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable rate limiting",
              "examples": [true, false]
            },
            "requests_per_sec": {
              "type": "integer",
              "minimum": 1,
              "description": "Requests per second",
              "examples": [10, 50, 100]
            },
            "requests_per_min": {
              "type": "integer",
              "minimum": 1,
              "description": "Requests per minute",
              "examples": [100, 500, 1000]
            },
            "burst": {
              "type": "integer",
              "minimum": 1,
              "description": "Burst size",
              "examples": [10, 50, 100]
            }
          }
        },
        "retry": {
          "type": "object",
          "description": "Retry configuration",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "max_attempts": {
              "type": "integer",
              "minimum": 1
            },
            "backoff_ms": {
              "type": "integer",
              "minimum": 1
            },
            "backoff_multiplier": {
              "type": "number",
              "minimum": 1
            },
            "max_backoff_ms": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "builtin_tools": {
          "type": "object",
          "description": "Built-in tools configuration",
          "properties": {
            "filesystem": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "timeout_sec": {
                  "type": "integer"
                },
                "max_file_size_mb": {
                  "type": "integer"
                }
              }
            },
            "shell": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "timeout_sec": {
                  "type": "integer"
                },
                "allowed_commands": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "http": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "timeout_sec": {
                  "type": "integer"
                },
                "max_response_size_mb": {
                  "type": "integer"
                }
              }
            },
            "code": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "timeout_sec": {
                  "type": "integer"
                },
                "languages": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "hot_reload": {
          "type": "object",
          "description": "Hot reload configuration",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "check_interval_sec": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    }
  },
  "additionalProperties": false
}