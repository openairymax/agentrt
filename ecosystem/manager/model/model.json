{
    "_config_version": "1.0.0",
    "_owner": {
        "module": "llm_d",
        "description": "JSON version of model.yaml for llm_d config loading"
    },

    "providers": [
        {
            "name": "openai",
            "api_key_env": "OPENAI_API_KEY",
            "base_url": "https://api.openai.com/v1",
            "default_model": "gpt-4-turbo",
            "timeout_sec": 60,
            "max_retries": 3,
            "models": [
                "gpt-4",
                "gpt-4-turbo",
                "gpt-3.5-turbo",
                "text-embedding-3-small",
                "text-embedding-3-large"
            ]
        },
        {
            "name": "anthropic",
            "api_key_env": "ANTHROPIC_API_KEY",
            "base_url": "https://api.anthropic.com",
            "default_model": "claude-3-sonnet",
            "timeout_sec": 120,
            "max_retries": 3,
            "models": [
                "claude-3-opus",
                "claude-3-sonnet",
                "claude-3-haiku"
            ]
        },
        {
            "name": "deepseek",
            "api_key_env": "DEEPSEEK_API_KEY",
            "base_url": "https://api.deepseek.com",
            "default_model": "deepseek-chat",
            "timeout_sec": 60,
            "max_retries": 3,
            "models": [
                "deepseek-chat"
            ]
        },
        {
            "name": "google",
            "api_key_env": "GOOGLE_AI_API_KEY",
            "base_url": "https://generativelanguage.googleapis.com",
            "default_model": "gemini-pro",
            "timeout_sec": 60,
            "max_retries": 3,
            "models": [
                "gemini-pro",
                "gemini-pro-vision"
            ]
        },
        {
            "name": "local",
            "api_key_env": "",
            "base_url": "http://localhost:11434",
            "default_model": "llama-3-70b",
            "timeout_sec": 120,
            "max_retries": 2,
            "models": [
                "llama-3-70b"
            ]
        }
    ],

    "models": [
        {
            "name": "gpt-4",
            "provider": "openai",
            "context_window": 128000,
            "input_cost_per_1k": 0.03,
            "output_cost_per_1k": 0.06,
            "capabilities": ["chat", "function_calling", "json_mode", "streaming"],
            "default": false,
            "max_concurrency": 10,
            "timeout_sec": 60
        },
        {
            "name": "gpt-4-turbo",
            "provider": "openai",
            "context_window": 128000,
            "input_cost_per_1k": 0.01,
            "output_cost_per_1k": 0.03,
            "capabilities": ["chat", "function_calling", "json_mode", "vision", "streaming"],
            "default": true,
            "max_concurrency": 20,
            "timeout_sec": 60
        },
        {
            "name": "gpt-3.5-turbo",
            "provider": "openai",
            "context_window": 16000,
            "input_cost_per_1k": 0.0015,
            "output_cost_per_1k": 0.002,
            "capabilities": ["chat", "function_calling", "streaming"],
            "default": false,
            "max_concurrency": 50,
            "timeout_sec": 30
        },
        {
            "name": "claude-3-opus",
            "provider": "anthropic",
            "context_window": 200000,
            "input_cost_per_1k": 0.015,
            "output_cost_per_1k": 0.075,
            "capabilities": ["chat", "vision", "streaming"],
            "default": false,
            "max_concurrency": 10,
            "timeout_sec": 120
        },
        {
            "name": "claude-3-sonnet",
            "provider": "anthropic",
            "context_window": 200000,
            "input_cost_per_1k": 0.003,
            "output_cost_per_1k": 0.015,
            "capabilities": ["chat", "streaming"],
            "default": false,
            "max_concurrency": 20,
            "timeout_sec": 60
        },
        {
            "name": "claude-3-haiku",
            "provider": "anthropic",
            "context_window": 200000,
            "input_cost_per_1k": 0.00025,
            "output_cost_per_1k": 0.00125,
            "capabilities": ["chat", "streaming"],
            "default": false,
            "max_concurrency": 50,
            "timeout_sec": 30
        },
        {
            "name": "deepseek-chat",
            "provider": "deepseek",
            "context_window": 64000,
            "input_cost_per_1k": 0.0001,
            "output_cost_per_1k": 0.0002,
            "capabilities": ["chat", "function_calling", "streaming"],
            "default": false,
            "max_concurrency": 20,
            "timeout_sec": 60
        },
        {
            "name": "llama-3-70b",
            "provider": "local",
            "context_window": 8192,
            "input_cost_per_1k": 0.0,
            "output_cost_per_1k": 0.0,
            "capabilities": ["chat", "streaming"],
            "default": false,
            "max_concurrency": 5,
            "timeout_sec": 120
        },
        {
            "name": "text-embedding-3-small",
            "provider": "openai",
            "context_window": 8191,
            "input_cost_per_1k": 0.00002,
            "output_cost_per_1k": 0.0,
            "capabilities": ["embedding"],
            "default": false,
            "max_concurrency": 100,
            "timeout_sec": 30
        },
        {
            "name": "text-embedding-3-large",
            "provider": "openai",
            "context_window": 8191,
            "input_cost_per_1k": 0.00013,
            "output_cost_per_1k": 0.0,
            "capabilities": ["embedding"],
            "default": false,
            "max_concurrency": 50,
            "timeout_sec": 30
        }
    ],

    "global": {
        "default_provider": "openai",
        "default_model": "gpt-4-turbo",
        "default_embedding_model": "text-embedding-3-small",
        "default_timeout_sec": 60,
        "cache_capacity": 1024,
        "cache_ttl_sec": 3600,
        "max_retries": 3,
        "timeout_ms": 30000
    },

    "routing": {
        "task_type_mapping": {
            "planning": "gpt-4",
            "coding": "gpt-4-turbo",
            "analysis": "claude-3-opus",
            "chat": "gpt-3.5-turbo",
            "embedding": "text-embedding-3-small"
        },
        "complexity_mapping": {
            "high": "gpt-4",
            "medium": "gpt-4-turbo",
            "low": "gpt-3.5-turbo"
        },
        "cost_optimization": {
            "enabled": true,
            "prefer_cheaper": false,
            "max_cost_per_request": 1.0
        }
    }
}
