# AgentOS 环境变量配置模板
# 复制此文件为 .env 并根据实际情况修改

# ==================== 基础配置 ====================

# 环境模式：development, production, test
AGENTOS_ENV=development

# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
AGENTOS_LOG_LEVEL=INFO

# 是否启用详细日志
AGENTOS_VERBOSE=false

# ==================== 路径配置 ====================

# 数据存储根目录（绝对路径）
AGENTOS_DATA_ROOT=/var/lib/agentos/heapstore

# 日志目录
AGENTOS_LOG_DIR=${AGENTOS_DATA_ROOT}/logs

# 内核数据目录
AGENTOS_KERNEL_DIR=${AGENTOS_DATA_ROOT}/kernel

# 注册表目录
AGENTOS_REGISTRY_DIR=${AGENTOS_DATA_ROOT}/registry

# 追踪数据目录
AGENTOS_TRACES_DIR=${AGENTOS_DATA_ROOT}/traces

# 模型权重目录
AGENTOS_MODELS_DIR=${AGENTOS_DATA_ROOT}/models

# ==================== LLM 服务配置 ====================

# OpenAI API 密钥
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI API 基础 URL（可选，用于代理）
OPENAI_BASE_URL=https://api.openai.com/v1

# 默认嵌入模型
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# DeepSeek API 密钥（如使用）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek API 基础 URL
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Anthropic API 密钥
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Anthropic API 基础 URL（可选，用于代理）
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google AI API 密钥
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# Google AI API 基础 URL
GOOGLE_AI_BASE_URL=https://generativelanguage.googleapis.com

# ==================== 向量检索配置 ====================

# FAISS 索引类型：IVF, HNSW, Flat
FAISS_INDEX_TYPE=IVF

# FAISS 索引参数（IVF 的聚类数）
FAISS_NLIST=1024

# FAISS 量化参数（PQ 的码长）
FAISS_M=64

# 向量维度（根据嵌入模型自动设置）
VECTOR_DIMENSION=1536

# 是否使用 GPU 加速（需要 FAISS GPU 版本）
FAISS_USE_GPU=false

# ==================== 记忆系统配置 ====================

# 记忆存储类型：filesystem, sqlite, hybrid
MEMORY_STORAGE_TYPE=hybrid

# L1 原始卷存储路径
MEMORY_L1_PATH=${AGENTOS_DATA_ROOT}/memory/l1

# L2 特征层索引路径
MEMORY_L2_INDEX_PATH=${AGENTOS_DATA_ROOT}/memory/l2_index

# L3 结构层数据路径
MEMORY_L3_PATH=${AGENTOS_DATA_ROOT}/memory/l3

# L4 模式层数据路径
MEMORY_L4_PATH=${AGENTOS_DATA_ROOT}/memory/l4

# 记忆写入模式：sync, async
MEMORY_WRITE_MODE=async

# 异步写入批大小
MEMORY_BATCH_SIZE=100

# LRU 缓存大小
MEMORY_CACHE_SIZE=1000

# 遗忘策略：ebbinghaus, linear, lru, lfu
MEMORY_FORGET_STRATEGY=ebbinghaus

# 遗忘曲线半衰期（天）
MEMORY_HALF_LIFE=7

# ==================== 核心服务配置 ====================

# LLM 服务地址
LLM_SERVICE_HOST=localhost

# LLM 服务端口
AGENTOS_LLM_SERVICE_PORT=8080
LLM_SERVICE_PORT=8080

# 市场服务地址
MARKET_SERVICE_HOST=localhost

# 市场服务端口
MARKET_SERVICE_PORT=8002

# 监控服务地址
MONIT_SERVICE_HOST=localhost

# 监控服务端口
MONIT_SERVICE_PORT=8003

# 权限服务地址
PERM_SERVICE_HOST=localhost

# 权限服务端口
PERM_SERVICE_PORT=8004

# 调度服务地址
SCHED_SERVICE_HOST=localhost

# 调度服务端口
SCHED_SERVICE_PORT=8005

# 工具服务地址
TOOL_SERVICE_HOST=localhost

# 工具服务端口
TOOL_SERVICE_PORT=8006

# ==================== IPC 配置 ====================

# IPC Socket 路径（Unix-like 系统）
IPC_SOCKET_PATH=/tmp/agentos/ipc.sock

# IPC 最大连接数
IPC_MAX_CONNECTIONS=1024

# IPC 超时时间（秒）
IPC_TIMEOUT=30

# IPC 重试次数
IPC_RETRY_COUNT=3

# ==================== 任务调度配置 ====================

# 调度策略：round_robin, priority, adaptive
SCHEDULER_POLICY=round_robin

# 默认任务优先级（1-10，10 最高）
DEFAULT_PRIORITY=5

# 任务超时时间（秒）
TASK_TIMEOUT=300

# 最大并发任务数
MAX_CONCURRENT_TASKS=100

# 任务重试次数
TASK_RETRY_COUNT=3

# ==================== OpenTelemetry 配置 ====================

# 是否启用追踪
OTEL_ENABLED=false

# OTLP 导出器端点
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# 服务名称
OTEL_SERVICE_NAME=agentos

# 采样率（0.0-1.0）
OTEL_SAMPLE_RATE=1.0

# 是否导出到控制台（调试用）
OTEL_CONSOLE_EXPORT=false

# ==================== 安全配置 ====================

# API 密钥认证开关
API_KEY_AUTH_ENABLED=true

# 管理员 API 密钥（生产环境请务必修改）
ADMIN_API_KEY=change_this_to_secure_random_string

# JWT Token 密钥（用于服务间认证）
JWT_SECRET_KEY=change_this_to_secure_random_string

# Token 过期时间（小时）
JWT_TOKEN_EXPIRY=24

# WARNING: In production, restrict CORS origins to your frontend domain(s)
# CORS 允许的来源（逗号分隔）
CORS_ORIGINS=${CORS_ORIGINS:-http://localhost:3000}

# 是否启用 HTTPS
HTTPS_ENABLED=false

# SSL 证书路径
SSL_CERT_PATH=/path/to/cert.pem

# SSL 私钥路径
SSL_KEY_PATH=/path/to/key.pem

# ==================== 性能调优 ====================

# 工作进程数（0 表示自动检测 CPU 核心数）
WORKER_PROCESSES=0

# 每个进程的最大线程数
MAX_THREADS_PER_PROCESS=4

# 内存限制（MB，0 表示无限制）
MEMORY_LIMIT_MB=0

# 磁盘空间警告阈值（GB）
DISK_SPACE_WARNING_GB=10

# 网络带宽限制（Mbps，0 表示无限制）
NETWORK_BANDWIDTH_LIMIT=0

# ==================== 数据库配置 ====================

# SQLite 数据库路径
SQLITE_DB_PATH=${AGENTOS_REGISTRY_DIR}/agents.db

# SQLite 连接池大小
SQLITE_POOL_SIZE=10

# SQLite 超时时间（秒）
SQLITE_TIMEOUT=30

# 是否启用 WAL 模式
SQLITE_WAL_MODE=true

# ==================== Redis 配置（可选） ====================

# 是否启用 Redis 缓存
REDIS_ENABLED=false

# Redis 主机
REDIS_HOST=localhost

# Redis 端口
REDIS_PORT=6379

# Redis 密码
REDIS_PASSWORD=

# Redis 数据库编号
REDIS_DB=0

# Redis 键前缀
REDIS_PREFIX=agentos

# ==================== 特性开关 ====================

# 是否启用 L4 模式层（实验性）
FEATURE_L4_PATTERN=false

# 是否启用图神经网络编码（实验性）
FEATURE_GNN_ENCODING=false

# 是否启用强化学习优化（实验性）
FEATURE_RL_OPTIMIZATION=false

# 是否启用分布式集群（规划中）
FEATURE_DISTRIBUTED_CLUSTER=false

# 是否启用自动记忆进化
FEATURE_AUTO_MEMORY_EVOLUTION=true

# 是否启用跨模态检索（规划中）
FEATURE_CROSS_MODAL_RETRIEVAL=false

# ==================== 开发和调试 ====================

# 是否启用调试模式
DEBUG_MODE=false

# 是否打印 SQL 语句
DEBUG_SQL=false

# 是否打印 IPC 消息
DEBUG_IPC=false

# 是否打印内存使用情况
DEBUG_MEMORY=false

# 性能分析输出目录
PROFILING_OUTPUT_DIR=${AGENTOS_DATA_ROOT}/profiling

# ==================== 其他配置 ====================

# 时区设置
TZ=Asia/Shanghai

# 语言设置：zh_CN, en_US
LANGUAGE=zh_CN

# 字符集
PYTHONIOENCODING=utf-8

# 临时目录
TMPDIR=/tmp/agentos

# ==================== 通知配置（可选） ====================

# 邮件通知开关
EMAIL_NOTIFICATIONS_ENABLED=false

# SMTP 服务器
SMTP_HOST=smtp.example.com

# SMTP 端口
SMTP_PORT=587

# SMTP 用户名
SMTP_USER=your_email@example.com

# SMTP 密码
SMTP_PASSWORD=your_smtp_password

# 告警接收邮箱
ALERT_EMAIL=admin@example.com

# Slack Webhook（可选）
SLACK_WEBHOOK_URL=

# Discord Webhook（可选）
DISCORD_WEBHOOK_URL=

# ==================== 监控告警 ====================

# CPU 使用率告警阈值（%）
CPU_ALERT_THRESHOLD=90

# 内存使用率告警阈值（%）
MEMORY_ALERT_THRESHOLD=85

# 磁盘使用率告警阈值（%）
DISK_ALERT_THRESHOLD=90

# 请求延迟告警阈值（毫秒）
LATENCY_ALERT_THRESHOLD_MS=1000

# 错误率告警阈值（%）
ERROR_RATE_THRESHOLD=5

# ==================== 备份和恢复 ====================

# 是否启用自动备份
AUTO_BACKUP_ENABLED=false

# 备份目录
BACKUP_DIR=${AGENTOS_DATA_ROOT}/backups

# 备份频率：hourly, daily, weekly
BACKUP_FREQUENCY=daily

# 保留备份数量
BACKUP_RETENTION_COUNT=7

# 备份压缩：gzip, bz2, none
BACKUP_COMPRESSION=gzip

# ==================== 结束 ====================
# 请确保已修改所有需要配置的项
# 运行 ./validate.sh 验证配置是否正确

