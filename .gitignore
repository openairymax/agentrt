# =============================================================================

!agentos/atoms/**/CMakeLists.txt
!agentos/atomslite/**/CMakeLists.txt
!agentos/commons/**/CMakeLists.txt
!agentos/commons/tests/CMakeLists.txt
!agentos/cupolas/CMakeLists.txt
!agentos/daemon/**/CMakeLists.txt
!agentos/gateway/CMakeLists.txt
!agentos/heapstore/**/CMakeLists.txt
!tests/unit/**/CMakeLists.txt

# 根目录项目配置
!pyproject.toml

# =============================================================================
# 21f. toolkit/ 语言 SDK 配置
# =============================================================================

!agentos/toolkit/python/pyproject.toml
!agentos/toolkit/python/setup.py
!agentos/toolkit/go/go.mod
!agentos/toolkit/rust/Cargo.toml
!agentos/toolkit/typescript/package.json
