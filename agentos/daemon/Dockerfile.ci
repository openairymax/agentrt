# AgentOS daemon 模块独立构建 CI Docker 镜像
# 用于 daemon 模块的独立构建和测试

FROM ubuntu:22.04 AS builder

LABEL maintainer="SPHARX Team <devops@spharx.cn>"
LABEL version="1.0.0"
LABEL description="AgentOS daemon Build Environment"

ENV DEBIAN_FRONTEND=noninteractive \
    TZ=Asia/Shanghai \
    BUILD_TYPE=Release \
    CC=gcc

WORKDIR /build

# 安装构建依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    ninja-build \
    pkg-manager \
    git \
    curl \
    libyaml-dev \
    libcjson-dev \
    libcurl4-openssl-dev \
    lcov \
    cppcheck \
    clang-format \
    clang-tidy \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# 复制源代码
COPY . /build

# 构建 bases 库
RUN cd /build/daemon/bases && \
    mkdir -p build && cd build && \
    cmake .. -G "Ninja" \
        -DCMAKE_BUILD_TYPE=${BUILD_TYPE} \
        -DBUILD_TESTS=ON \
        -DBUILD_COVERAGE=OFF && \
    ninja && \
    ninja install

# 构建 llm_d
RUN cd /build/daemon/llm_d && \
    mkdir -p build && cd build && \
    cmake .. -G "Ninja" \
        -DCMAKE_BUILD_TYPE=${BUILD_TYPE} \
        -DBUILD_TESTS=ON && \
    ninja && \
    ninja install

# 构建 tool_d
RUN cd /build/daemon/tool_d && \
    mkdir -p build && cd build && \
    cmake .. -G "Ninja" \
        -DCMAKE_BUILD_TYPE=${BUILD_TYPE} \
        -DBUILD_TESTS=ON && \
    ninja && \
    ninja install

# 构建 monit_d
RUN cd /build/daemon/monit_d && \
    mkdir -p build && cd build && \
    cmake .. -G "Ninja" \
        -DCMAKE_BUILD_TYPE=${BUILD_TYPE} \
        -DBUILD_TESTS=ON && \
    ninja && \
    ninja install

# 构建 sched_d
RUN cd /build/daemon/sched_d && \
    mkdir -p build && cd build && \
    cmake .. -G "Ninja" \
        -DCMAKE_BUILD_TYPE=${BUILD_TYPE} \
        -DBUILD_TESTS=ON && \
    ninja && \
    ninja install

# 构建 market_d
RUN cd /build/daemon/market_d && \
    mkdir -p build && cd build && \
    cmake .. -G "Ninja" \
        -DCMAKE_BUILD_TYPE=${BUILD_TYPE} \
        -DBUILD_TESTS=ON && \
    ninja && \
    ninja install

# 运行测试
RUN cd /build/daemon/bases/build && ctest --output-on-failure || true
RUN cd /build/daemon/llm_d/build && ctest --output-on-failure || true
RUN cd /build/daemon/tool_d/build && ctest --output-on-failure || true
RUN cd /build/daemon/monit_d/build && ctest --output-on-failure || true
RUN cd /build/daemon/sched_d/build && ctest --output-on-failure || true
RUN cd /build/daemon/market_d/build && ctest --output-on-failure || true

# ============================================================================
# 运行时镜像
# ============================================================================
FROM ubuntu:22.04 AS runtime

LABEL maintainer="SPHARX Team <devops@spharx.cn>"
LABEL version="1.0.0"
LABEL description="AgentOS daemon Runtime"

ENV DEBIAN_FRONTEND=noninteractive \
    TZ=Asia/Shanghai \
    AGENTOS_SERVICES_ROOT=/opt/agentos/services \
    AGENTOS_LOG_DIR=/var/log/agentos \
    AGENTOS_CONFIG_DIR=/etc/agentos

WORKDIR /app

# 安装运行时依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# 从构建阶段复制二进制文件
COPY --from=builder /opt/agentos/services/bin/* ${AGENTOS_SERVICES_ROOT}/bin/
COPY --from=builder /opt/agentos/services/lib/* ${AGENTOS_SERVICES_ROOT}/lib/

# 创建目录结构
RUN mkdir -p ${AGENTOS_SERVICES_ROOT}/{bin,lib,etc,var} \
    && mkdir -p ${AGENTOS_CONFIG_DIR} \
    && mkdir -p ${AGENTOS_LOG_DIR} \
    && chmod -R 755 ${AGENTOS_SERVICES_ROOT} \
    && chmod -R 755 ${AGENTOS_LOG_DIR}

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD pgrep -f 'agentos-' || exit 1

EXPOSE 8080 8081 8082 8083 8084

CMD ["/bin/bash"]