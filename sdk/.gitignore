# =============================================================================
# AgentRT SDK .gitignore
# 版本: 1.0.0
# 最后更新: 2026-07-02
# 说明: SDK 多语言构建产物排除规则
# Part of Airymax open-source project (agentrt)
# =============================================================================

# Python SDK
python/__pycache__/
python/*.pyc
python/*.egg-info/
python/dist/
python/build/
python/.pytest_cache/
python/.mypy_cache/
python/.ruff_cache/
python/.coverage
python/htmlcov/
python/.venv/
python/venv/

# Go SDK
go/vendor/
go/*.test
go/*.out
go/coverage/

# Rust SDK (库 crate)
rust/target/
rust/Cargo.lock
rust/debug/
rust/release/

# Rust CLI (二进制 crate — Cargo.lock 应跟踪)
cli/target/
tui/target/

# TypeScript SDK
typescript/node_modules/
typescript/dist/
typescript/build/
typescript/coverage/
typescript/.tsbuildinfo
